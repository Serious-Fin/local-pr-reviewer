{
  "name": "local-pr-reviewer",
  "displayName": "local-pr-reviewer",
  "description": "TODO-DESCRIPTION",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "local-reviewer",
          "title": "Local Reviewer",
          "icon": "resources/temp-icon.svg"
        }
      ]
    },
    "views": {
      "local-reviewer": [
        {
          "id": "localReviewerBranches",
          "name": "Branches",
          "icon": "resources/temp-icon.svg",
          "contextualTitle": "Local Reviewer"
        },
        { "id": "changedFilesView", "name": "Changed Files" }
      ]
    },
    "commands": [
      {
        "command": "localReviewerBranches.refreshBranches",
        "title": "Local Reviewer: Refresh",
        "icon": {
          "light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
